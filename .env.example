# Tachles — environment variables
# Copy to .env.local for local development: `supabase functions serve --env-file .env.local`
# In production set these as Edge Function secrets: `supabase secrets set --env-file .env`

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Secret used to verify webhook calls (sent by Telegram as X-Telegram-Bot-Api-Secret-Token).
# Register it when calling setWebhook with `secret_token`.
TELEGRAM_WEBHOOK_SECRET=
# Public bot username without @, used for invite links.
BOT_USERNAME=
# Optional HTTPS URL of the deployed Telegram Mini App.
MINI_APP_URL=

# --- Standalone web app ---
# Public HTTPS URL of the PWA. Used for CORS and Telegram account-link URLs.
WEB_APP_URL=
# Optional comma-separated allowlist. Leave empty for a normal self-hosted
# multi-user instance. The official deployment sets this to the owner's email.
WEB_ALLOWED_EMAILS=
# At least 32 random characters. Used as a server-side pepper when hashing
# short-lived account-link codes; never expose it to the browser.
PROFILE_LINK_SECRET=

# --- Supabase ---
# Locally these are injected automatically when running `supabase start`.
# Set them in .env.local only if you need to point at a remote project.
SUPABASE_PROJECT_REF=
# Used only by the local setup/deploy scripts. Never upload it as a function secret.
SUPABASE_DB_PASSWORD=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Reminder scheduler ---
# Shared secret that pg_cron sends to the dispatch-reminders function (header x-dispatch-secret).
# Store the same value in Supabase Vault as 'dispatch_secret' (see migration 0002_cron.sql).
DISPATCH_SECRET=

# --- PWA Web Push ---
# Generate one P-256 VAPID key pair. The public key is returned to authenticated
# clients; the private key stays only in Supabase Edge Function secrets.
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Intent / date parsing (reminders) ---
ANTHROPIC_API_KEY=
# Optional; defaults to claude-sonnet-4-6.
LLM_MODEL=

# --- Voice transcription (lists) ---
OPENAI_API_KEY=
OPENAI_RESEARCH_MODEL=gpt-5.5
# Optional; defaults to gpt-4o-transcribe.
OPENAI_TRANSCRIBE_MODEL=
# Optional; defaults to text-embedding-3-small.
OPENAI_EMBEDDING_MODEL=

# --- Google Calendar / Drive ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=
