{
  "imports": {
    "@supabase/supabase-js": "npm:@supabase/supabase-js@2",
    "rrule": "npm:rrule@2.8.1",
    "web-push": "npm:web-push@3.6.7"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "tasks": {
    "serve": "supabase functions serve --env-file .env.local",
    "fmt": "deno fmt supabase/functions",
    "fmt:check": "deno fmt --check supabase/functions scripts",
    "lint": "deno lint supabase/functions",
    "test": "deno test --allow-all supabase/functions",
    "check": "deno check supabase/functions/**/*.ts",
    "verify": "deno task fmt:check && deno task lint && deno task test && deno task check"
  }
}
